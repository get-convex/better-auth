[
  {
    "label": "copy .env.local into new worktree",
    "command": "cp",
    "args": [
      "$ZED_MAIN_GIT_WORKTREE/examples/react/.env.local",
      "$ZED_WORKTREE_ROOT/examples/react/.env.local"
    ],
    "hooks": ["create_worktree"],
    "reveal": "no_focus",
    "hide": "on_success"
  },
  {
    "label": "install dependencies",
    "command": "npm install && cd examples/react && npm install",
    "hooks": ["create_worktree"],
    "reveal": "no_focus",
    "hide": "on_success"
  },
  {
    "label": "dev",
    "command": "npm",
    "args": ["run dev"],
    "allow_concurrent_runs": false
  }
]
